# Токен бота от @BotFather
BOT_TOKEN=123456:PUT_YOUR_TOKEN_HERE

# Telegram ID первого суперадмина (узнать свой ID можно у @userinfobot)
SUPERADMIN_ID=000000000

# Путь к файлу БД (по умолчанию survey.db в корне проекта)
DB_PATH=survey.db

# Пароль для кнопки «Удалить весь опрос» в админке (полная очистка результатов)
WIPE_PASSWORD=PUT_A_STRONG_PASSWORD_HERE
